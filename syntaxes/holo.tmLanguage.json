{
  "scopeName": "text.holo",
  "patterns": [
    { "include": "#comment" },
    { "include": "#doctype" },
    { "include": "#escape_sequence" },
    { "include": "#expression" },
    { "include": "#component_tag_open" },
    { "include": "#component_tag_close" },
    { "include": "#tag_open" },
    { "include": "#tag_close" }
  ],
  "repository": {
    "tag_open": {
      "begin": "(<)([a-z][a-z0-9-]*)",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.holo" },
        "2": { "name": "entity.name.tag.holo" }
      },
      "end": "(/>|>)",
      "endCaptures": {
        "1": { "name": "punctuation.definition.tag.end.holo" }
      },
      "name": "meta.tag.holo",
      "patterns": [
        { "include": "#tag_innards" }
      ]
    },
    "tag_close": {
      "begin": "(</)([a-z][a-z0-9-]*)",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.holo" },
        "2": { "name": "entity.name.tag.holo" }
      },
      "end": "(>)",
      "endCaptures": {
        "1": { "name": "punctuation.definition.tag.end.holo" }
      },
      "name": "meta.tag.holo"
    },
    "tag_innards": {
      "patterns": [
        { "include": "#attribute_name" },
        { "include": "#attribute_equals" },
        { "include": "#attribute_value_double" },
        { "include": "#expression" }
      ]
    },
    "attribute_value_double": {
      "begin": "\"",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.string.begin.holo" }
      },
      "end": "\"",
      "endCaptures": {
        "0": { "name": "punctuation.definition.string.end.holo" }
      },
      "name": "string.quoted.double.holo",
      "patterns": [
        { "include": "#expression" }
      ]
    },
    "component_tag_close": {
      "begin": "(</)([A-Z][a-zA-Z0-9]*(?:\\.[A-Z][a-zA-Z0-9]*)*)",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.holo" },
        "2": { "name": "entity.name.type.component.holo" }
      },
      "end": "(>)",
      "endCaptures": {
        "1": { "name": "punctuation.definition.tag.end.holo" }
      },
      "name": "meta.tag.component.holo"
    },
    "component_tag_open": {
      "begin": "(<)([A-Z][a-zA-Z0-9]*(?:\\.[A-Z][a-zA-Z0-9]*)*)",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.holo" },
        "2": { "name": "entity.name.type.component.holo" }
      },
      "end": "(/>|>)",
      "endCaptures": {
        "1": { "name": "punctuation.definition.tag.end.holo" }
      },
      "name": "meta.tag.component.holo",
      "patterns": [
        { "include": "#tag_innards" }
      ]
    },
    "comment": {
      "begin": "<!--",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.comment.begin.holo" }
      },
      "end": "-->",
      "endCaptures": {
        "0": { "name": "punctuation.definition.comment.end.holo" }
      },
      "name": "comment.block.holo"
    },
    "expression": {
      "begin": "\\{",
      "beginCaptures": {
        "0": { "name": "punctuation.section.embedded.begin.holo" }
      },
      "end": "\\}",
      "endCaptures": {
        "0": { "name": "punctuation.section.embedded.end.holo" }
      },
      "name": "meta.embedded.expression.holo",
      "patterns": [
        { "include": "#expression_innards" },
        { "include": "source.elixir" }
      ]
    },
    "expression_innards": {
      "begin": "\\{",
      "end": "\\}",
      "patterns": [
        { "include": "#expression_innards" },
        { "include": "source.elixir" }
      ]
    },
    "escape_sequence": {
      "match": "\\\\[{}#$]",
      "name": "constant.character.escape.holo"
    },
    "doctype": {
      "match": "(<!)([Dd][Oo][Cc][Tt][Yy][Pp][Ee])\\s+([^>]*)(>)",
      "captures": {
        "1": { "name": "punctuation.definition.tag.begin.holo" },
        "2": { "name": "entity.name.tag.doctype.holo" },
        "3": { "name": "string.unquoted.holo" },
        "4": { "name": "punctuation.definition.tag.end.holo" }
      },
      "name": "meta.tag.metadata.doctype.holo"
    },
    "attribute_equals": {
      "match": "=",
      "name": "punctuation.separator.key-value.holo"
    },
    "attribute_name": {
      "match": "[a-zA-Z_:][a-zA-Z0-9_.:-]*",
      "name": "entity.other.attribute-name.holo"
    }
  }
}
