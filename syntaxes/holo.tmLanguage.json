{
  "scopeName": "text.holo",
  "patterns": [
    { "include": "#tag_open" },
    { "include": "#tag_close" }
  ],
  "repository": {
    "tag_open": {
      "begin": "(<)([a-z][a-z0-9-]*)",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.holo" },
        "2": { "name": "entity.name.tag.holo" }
      },
      "end": "(/>|>)",
      "endCaptures": {
        "1": { "name": "punctuation.definition.tag.end.holo" }
      },
      "name": "meta.tag.holo",
      "patterns": [
        { "include": "#tag_innards" }
      ]
    },
    "tag_close": {
      "begin": "(</)([a-z][a-z0-9-]*)",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.holo" },
        "2": { "name": "entity.name.tag.holo" }
      },
      "end": "(>)",
      "endCaptures": {
        "1": { "name": "punctuation.definition.tag.end.holo" }
      },
      "name": "meta.tag.holo"
    },
    "tag_innards": {
      "patterns": [
        { "include": "#attribute_name" }
      ]
    },
    "attribute_name": {
      "match": "[a-zA-Z_:][a-zA-Z0-9_.:-]*",
      "name": "entity.other.attribute-name.holo"
    }
  }
}
