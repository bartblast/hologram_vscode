{
  "scopeName": "text.holo",
  "patterns": [
    { "include": "#comment" },
    { "include": "#doctype" },
    { "include": "#escape_sequence" },
    { "include": "#block_raw" },
    { "include": "#block_if_open" },
    { "include": "#block_if_close" },
    { "include": "#block_else" },
    { "include": "#block_for_open" },
    { "include": "#block_for_close" },
    { "include": "#expression" },
    { "include": "#embedded_javascript" },
    { "include": "#embedded_css" },
    { "include": "#component_tag_open" },
    { "include": "#component_tag_close" },
    { "include": "#tag_open" },
    { "include": "#tag_close" }
  ],
  "repository": {
    "tag_open": {
      "begin": "(<)([a-z][a-z0-9-]*)",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.holo" },
        "2": { "name": "entity.name.tag.holo" }
      },
      "end": "(/>|>)",
      "endCaptures": {
        "1": { "name": "punctuation.definition.tag.end.holo" }
      },
      "name": "meta.tag.holo",
      "patterns": [
        { "include": "#tag_innards" }
      ]
    },
    "tag_close": {
      "begin": "(</)([a-z][a-z0-9-]*)",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.holo" },
        "2": { "name": "entity.name.tag.holo" }
      },
      "end": "(>)",
      "endCaptures": {
        "1": { "name": "punctuation.definition.tag.end.holo" }
      },
      "name": "meta.tag.holo"
    },
    "tag_innards": {
      "patterns": [
        { "include": "#attribute_name_event" },
        { "include": "#attribute_name" },
        { "include": "#attribute_equals" },
        { "include": "#attribute_value_double" },
        { "include": "#expression" }
      ]
    },
    "attribute_value_double": {
      "begin": "\"",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.string.begin.holo" }
      },
      "end": "\"",
      "endCaptures": {
        "0": { "name": "punctuation.definition.string.end.holo" }
      },
      "name": "string.quoted.double.holo",
      "patterns": [
        { "include": "#expression" }
      ]
    },
    "block_raw": {
      "begin": "(\\{%)(raw)(\\})",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.keyword.holo" },
        "2": { "name": "keyword.control.raw.holo" },
        "3": { "name": "punctuation.definition.keyword.holo" }
      },
      "end": "(\\{/)(raw)(\\})",
      "endCaptures": {
        "1": { "name": "punctuation.definition.keyword.holo" },
        "2": { "name": "keyword.control.raw.holo" },
        "3": { "name": "punctuation.definition.keyword.holo" }
      },
      "name": "meta.block.raw.holo",
      "contentName": "string.unquoted.raw.holo"
    },
    "block_else": {
      "match": "(\\{%)(else)(\\})",
      "captures": {
        "1": { "name": "punctuation.definition.keyword.holo" },
        "2": { "name": "keyword.control.else.holo" },
        "3": { "name": "punctuation.definition.keyword.holo" }
      },
      "name": "meta.block.else.holo"
    },
    "block_for_close": {
      "match": "(\\{/)(for)(\\})",
      "captures": {
        "1": { "name": "punctuation.definition.keyword.holo" },
        "2": { "name": "keyword.control.for.holo" },
        "3": { "name": "punctuation.definition.keyword.holo" }
      },
      "name": "meta.block.for.holo"
    },
    "block_for_open": {
      "begin": "(\\{%)(for)\\b",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.keyword.holo" },
        "2": { "name": "keyword.control.for.holo" }
      },
      "end": "(\\})",
      "endCaptures": {
        "1": { "name": "punctuation.definition.keyword.holo" }
      },
      "name": "meta.block.for.holo",
      "patterns": [
        { "include": "source.elixir" }
      ]
    },
    "block_if_close": {
      "match": "(\\{/)(if)(\\})",
      "captures": {
        "1": { "name": "punctuation.definition.keyword.holo" },
        "2": { "name": "keyword.control.if.holo" },
        "3": { "name": "punctuation.definition.keyword.holo" }
      },
      "name": "meta.block.if.holo"
    },
    "block_if_open": {
      "begin": "(\\{%)(if)\\b",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.keyword.holo" },
        "2": { "name": "keyword.control.if.holo" }
      },
      "end": "(\\})",
      "endCaptures": {
        "1": { "name": "punctuation.definition.keyword.holo" }
      },
      "name": "meta.block.if.holo",
      "patterns": [
        { "include": "source.elixir" }
      ]
    },
    "component_tag_close": {
      "begin": "(</)([A-Z][a-zA-Z0-9]*(?:\\.[A-Z][a-zA-Z0-9]*)*)",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.holo" },
        "2": { "name": "entity.name.type.component.holo" }
      },
      "end": "(>)",
      "endCaptures": {
        "1": { "name": "punctuation.definition.tag.end.holo" }
      },
      "name": "meta.tag.component.holo"
    },
    "component_tag_open": {
      "begin": "(<)([A-Z][a-zA-Z0-9]*(?:\\.[A-Z][a-zA-Z0-9]*)*)",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.holo" },
        "2": { "name": "entity.name.type.component.holo" }
      },
      "end": "(/>|>)",
      "endCaptures": {
        "1": { "name": "punctuation.definition.tag.end.holo" }
      },
      "name": "meta.tag.component.holo",
      "patterns": [
        { "include": "#tag_innards" }
      ]
    },
    "comment": {
      "begin": "<!--",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.comment.begin.holo" }
      },
      "end": "-->",
      "endCaptures": {
        "0": { "name": "punctuation.definition.comment.end.holo" }
      },
      "name": "comment.block.holo"
    },
    "attribute_name_event": {
      "match": "(\\$)([a-zA-Z][a-zA-Z0-9_]*)",
      "captures": {
        "1": { "name": "keyword.operator.event.holo" },
        "2": { "name": "entity.other.attribute-name.event.holo" }
      }
    },
    "expression": {
      "begin": "\\{",
      "beginCaptures": {
        "0": { "name": "punctuation.section.embedded.begin.holo" }
      },
      "end": "\\}",
      "endCaptures": {
        "0": { "name": "punctuation.section.embedded.end.holo" }
      },
      "name": "meta.embedded.expression.holo",
      "patterns": [
        { "include": "#expression_innards" },
        { "include": "source.elixir" }
      ]
    },
    "expression_innards": {
      "begin": "\\{",
      "end": "\\}",
      "patterns": [
        { "include": "#expression_innards" },
        { "include": "source.elixir" }
      ]
    },
    "embedded_css": {
      "begin": "(<)(style)\\b([^>]*)(>)",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.holo" },
        "2": { "name": "entity.name.tag.holo" },
        "3": { "patterns": [{ "include": "#tag_innards" }] },
        "4": { "name": "punctuation.definition.tag.end.holo" }
      },
      "end": "(</)(style)\\s*(>)",
      "endCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.holo" },
        "2": { "name": "entity.name.tag.holo" },
        "3": { "name": "punctuation.definition.tag.end.holo" }
      },
      "name": "meta.embedded.block.css.holo",
      "patterns": [
        { "include": "#block_raw" }
      ]
    },
    "embedded_javascript": {
      "begin": "(<)(script)\\b([^>]*)(>)",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.holo" },
        "2": { "name": "entity.name.tag.holo" },
        "3": { "patterns": [{ "include": "#tag_innards" }] },
        "4": { "name": "punctuation.definition.tag.end.holo" }
      },
      "end": "(</)(script)\\s*(>)",
      "endCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.holo" },
        "2": { "name": "entity.name.tag.holo" },
        "3": { "name": "punctuation.definition.tag.end.holo" }
      },
      "name": "meta.embedded.block.javascript.holo",
      "patterns": [
        { "include": "#block_raw" },
        { "include": "#escape_sequence" },
        { "include": "#expression" }
      ]
    },
    "escape_sequence": {
      "match": "\\\\[{}#$]",
      "name": "constant.character.escape.holo"
    },
    "doctype": {
      "match": "(<!)([Dd][Oo][Cc][Tt][Yy][Pp][Ee])\\s+([^>]*)(>)",
      "captures": {
        "1": { "name": "punctuation.definition.tag.begin.holo" },
        "2": { "name": "entity.name.tag.doctype.holo" },
        "3": { "name": "string.unquoted.holo" },
        "4": { "name": "punctuation.definition.tag.end.holo" }
      },
      "name": "meta.tag.metadata.doctype.holo"
    },
    "attribute_equals": {
      "match": "=",
      "name": "punctuation.separator.key-value.holo"
    },
    "attribute_name": {
      "match": "[a-zA-Z_:][a-zA-Z0-9_.:-]*",
      "name": "entity.other.attribute-name.holo"
    }
  }
}
