{
  "scopeName": "source.elixir",
  "patterns": [
    { "include": "#atom" },
    { "include": "#module_attribute" },
    { "include": "#number" },
    { "include": "#identifier" }
  ],
  "repository": {
    "atom": {
      "match": ":[a-zA-Z_][a-zA-Z0-9_]*[!?]?",
      "name": "constant.other.symbol.elixir"
    },
    "module_attribute": {
      "match": "@[a-zA-Z_][a-zA-Z0-9_]*",
      "name": "variable.other.attribute.elixir"
    },
    "number": {
      "match": "\\b\\d+(\\.\\d+)?\\b",
      "name": "constant.numeric.elixir"
    },
    "identifier": {
      "match": "\\b[a-z_][a-zA-Z0-9_]*[!?]?\\b",
      "name": "variable.other.elixir"
    }
  }
}
